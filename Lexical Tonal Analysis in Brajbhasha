# [6]. Safe lmer wrapper
safe_lmer <- function(formula, dat) {
  m <- try(lmer(formula, data = dat, REML = TRUE), silent = TRUE)
  if(inherits(m, "try-error")) {
    message("Model failed, simplifying random effects...")
    m <- lmer(update(formula, . ~ . - (1|Pair) + (1|Subject)), data = dat, REML = TRUE)}
  m}

