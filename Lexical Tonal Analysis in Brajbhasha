# Helper function for mixed models + emmeans
run_coart_analysis <- function(dv, data) {
  form <- as.formula(paste(dv, "~ Tone * TBU_syll * Syllable * Gender + (1|Subject) + (1|Pair)"))
  mod  <- safe_lmer(form, data)
