# Function to test Tone effect
test_tone_effect <- function(dataset_name, timepoint_num, data) {
  data_subset <- filter(data, Dataset == dataset_name, Timepoint == timepoint_num)
  if (n_distinct(data_subset$Tone) < 2) 
    return(tibble(Dataset = dataset_name, Timepoint = timepoint_num, p_value = NA, estimate = NA, df = NA, t_value = NA, note = "Insufficient Tone levels"))
  model <- lmer(F0_contour ~ Tone + (1 | Subject) + (1 | Pair), data = data_subset, REML = TRUE)
  coefs <- summary(model)$coefficients
  tone_row <- coefs[grep("ToneLow", rownames(coefs)), , drop = FALSE]
  if (nrow(tone_row) == 0) 
    return(tibble(Dataset = dataset_name, Timepoint = timepoint_num, p_value = NA, estimate = NA, df = NA, t_value = NA, note = "Tone coefficient not found"))
  tibble(Dataset = dataset_name, Timepoint = timepoint_num, p_value = tone_row[,"Pr(>|t|)"], estimate = tone_row[,"Estimate"], df = tone_row[,"df"], t_value = tone_row[,"t value"], note = NA_character_)}
# Grid of Dataset × Timepoint
test_grid <- expand.grid(Dataset = unique(contour_long$Dataset), Timepoint = unique(contour_long$Timepoint))
# Run all models
pointwise_results <- pmap_dfr(test_grid, ~ test_tone_effect(..1, ..2, contour_long), .progress = TRUE) %>%
  mutate(significant_uncorrected = p_value < 0.05, p_adjusted = p.adjust(p_value, "BH"), significant_fdr = p_adjusted < 0.05)
# View the results
print(pointwise_results, n = 110)
# Summarize contour_long for plotting
contour_summary <- contour_long %>%
  group_by(Dataset, Tone, Timepoint) %>%
  summarise(mean_F0 = mean(F0_contour, na.rm = TRUE), se_F0   = sd(F0_contour, na.rm = TRUE) / sqrt(n()), .groups = "drop")
# Merge with summary for plotting
contour_summary_with_sig <- contour_summary %>%
  left_join(select(pointwise_results, Dataset, Timepoint, significant_fdr, p_value), by = c("Dataset", "Timepoint"))
# Plot
ggplot(contour_summary_with_sig, aes(Timepoint, mean_F0, color = Tone, group = Tone)) +
  geom_line(size = 1) +
  geom_ribbon(aes(ymin = mean_F0 - se_F0, ymax = mean_F0 + se_F0, fill = Tone), alpha = 0.15, color = NA) +
  geom_point(data = . %>% filter(significant_fdr & Tone == "Neutral"), aes(y = mean_F0), shape = 18, size = 3, color = "black", show.legend = FALSE) +
  facet_wrap(~ Dataset, ncol = 2) +
  labs(title = "F0 trajectories by Tone with FDR-corrected significance", subtitle = "Black diamonds = significant (FDR < 0.05) Tone difference", x = "Normalized timepoints (0–10)", y = "F0 (Hz)") +
  theme(legend.position = "right", strip.background = element_rect(fill = "gray90", color = "gray60"))
# Summary table
significance_summary <- pointwise_results %>%
  group_by(Dataset) %>%
  summarise(n_significant_uncorrected = sum(significant_uncorrected, na.rm = TRUE), n_significant_fdr = sum(significant_fdr, na.rm = TRUE), percent_significant = mean(significant_fdr, na.rm = TRUE) * 100, .groups = "drop")
print(significance_summary)

