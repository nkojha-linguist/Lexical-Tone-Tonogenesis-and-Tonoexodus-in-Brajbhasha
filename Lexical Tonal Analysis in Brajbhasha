# [6c]. Moderator analysis
run_mods <- function(dv, dat, moderators) {
  mods <- map(moderators, ~{
    f <- as.formula(paste(dv, "~ Tone *", .x, "+ (1|Subject) + (1|Pair)"))
    safe_lmer(f, dat)}) %>% set_names(moderators)
  map(mods, anova)
  return(mods)}

# [6d]. Contrast-of-contrasts helper (unchanged but used for both DVs)
compare_contrast_sizes <- function(model, mod_var) {
  emms <- emmeans(model, as.formula(paste0("~ ", mod_var, " * Tone")))
  within <- contrast(emmeans(model, as.formula(paste0("~ Tone | ", mod_var))), method = "pairwise")
  groups <- unique(as.data.frame(emms)[[mod_var]])
  contrast_list <- combn(groups, 2, simplify = FALSE, FUN = function(g) {
    v <- rep(0, nrow(as.data.frame(emms)))
    v[as.data.frame(emms)[[mod_var]] == g[1] & as.data.frame(emms)$Tone == "Neutral"] <-  1
    v[as.data.frame(emms)[[mod_var]] == g[1] & as.data.frame(emms)$Tone == "Low"]     <- -1
    v[as.data.frame(emms)[[mod_var]] == g[2] & as.data.frame(emms)$Tone == "Neutral"] <- -1
    v[as.data.frame(emms)[[mod_var]] == g[2] & as.data.frame(emms)$Tone == "Low"]     <-  1
    setNames(list(v), paste0(g[1], "_vs_", g[2]))})
  diffdiff <- contrast(emms, contrast_list)
  list(emms = emms, within = within, diffdiff = diffdiff)}

